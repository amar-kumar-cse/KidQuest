{
  "name": "kidquest-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "frontend:start": "cd Frontend && npm run start",
    "frontend:ios": "cd Frontend && npm run ios",
    "frontend:android": "cd Frontend && npm run android",
    "frontend:typecheck": "cd Frontend && npm run type-check",
    "backend:functions:build": "cd Backend/functions && npm run build",
    "backend:functions:serve": "cd Backend && npx firebase emulators:start --only functions,firestore,auth",
    "dev": "concurrently \"npm:frontend:start\" \"npm:backend:functions:serve\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
