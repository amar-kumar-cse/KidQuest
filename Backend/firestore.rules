rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/Users/$(uid)).data;
    }

    function getUserFamily(uid) {
      return getUserData(uid).familyId;
    }

    function sameFamily(resourceFamilyId) {
      return isSignedIn() && resourceFamilyId == getUserFamily(request.auth.uid);
    }

    function isParentOf(taskData) {
      return isSignedIn() && request.auth.uid == taskData.parentId && sameFamily(taskData.familyId);
    }

    function isAssignedKid(taskData) {
      return isSignedIn() && request.auth.uid == taskData.assignedToUid && sameFamily(taskData.familyId);
    }

    function userRole() {
      return getUserData(request.auth.uid).role;
    }

    function isParent() {
      return isSignedIn() && userRole() == 'parent';
    }

    function isKid() {
      return isSignedIn() && userRole() == 'kid';
    }

    // ── Users Collection ──────────────────────────────────────────────
    match /Users/{userId} {
      // Reads: user may read own doc; parents in same family may read kid profiles
      allow read: if isUser(userId) || (isParent() && sameFamily(resource.data.familyId));

      // Creation: users may create their own profile with required fields
      allow create: if isUser(userId)
        && request.resource.data.keys().hasAll(['uid', 'email', 'name', 'role', 'familyId', 'createdAt'])
        && (request.resource.data.role == 'parent' || request.resource.data.role == 'kid');

      // Updates: user may update non-sensitive profile fields; parents may update their kid's profile fields.
      // Prevent client-side writes to XP/streak/family/role fields. Only server (Admin SDK / Cloud Functions)
      // should modify totalXp, currentStreak, bestStreak, lastCompletedAt, role, or familyId.
      allow update: if (
        // user updating own profile (allow only non-sensitive keys)
        isUser(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalXp', 'currentStreak', 'bestStreak', 'lastCompletedAt', 'role', 'familyId'])
      ) || (
        // parent updating kid's profile (allow only a limited set of non-sensitive fields)
        isParent()
          && sameFamily(resource.data.familyId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalXp', 'currentStreak', 'bestStreak', 'lastCompletedAt', 'role', 'familyId'])
      );

      // No client-side deletes
      allow delete: if false;
    }

    // ── Tasks Collection ─────────────────────────────────────────────
    match /Tasks/{taskId} {
      // Read: Parent (their tasks) or assigned Kid — only within same family
      allow read: if (isParentOf(resource.data) || isAssignedKid(resource.data)) && sameFamily(resource.data.familyId);

      // Create: Only parents, parentId must match UID
      allow create: if isParent()
        && request.auth.uid == request.resource.data.parentId
        && request.resource.data.familyId == getUserFamily(request.auth.uid)
        && request.resource.data.xp is int
        && request.resource.data.xp >= 1
        && request.resource.data.xp <= 9999
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll([
             'title', 'description', 'xp', 'status',
             'parentId', 'assignedToUid', 'familyId', 'createdAt', 'dueDate'
           ]);

      // Update:
      // Parent: full rights (approve, reject, edit) — but parentId is immutable
      // Kid: STRICTLY limited — only submit proof
      allow update: if (
        // Parent may update any non-family-breaking fields for tasks in their family
        isParentOf(resource.data)
        && request.resource.data.parentId == resource.data.parentId
        && request.resource.data.familyId == resource.data.familyId
      ) || (
        // Kid may only submit proof (transition pending -> pending_approval)
        isAssignedKid(resource.data)
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['status', 'proofUrl', 'completedAt', 'proofNote'])
        && request.resource.data.status == 'pending_approval'
        && request.resource.data.parentId == resource.data.parentId
        && request.resource.data.assignedToUid == resource.data.assignedToUid
        && request.resource.data.xp == resource.data.xp
      );

      // Delete: Only the parent who owns the task, only if not yet approved
      allow delete: if isParentOf(resource.data)
        && resource.data.status != 'completed';
    }

    // ── FamilyCodes Collection ────────────────────────────────────────
    // FIX: Previously ANY signed-in user could read ALL codes (enumeration risk)
    // Now: Parent can read their OWN code; kid verifies via Cloud Function only
    match /FamilyCodes/{code} {
      // Block all client-side reads to prevent enumeration and scraping.
      allow read: if false;

      // Parent may create a family code for their family (write-only from client)
      allow create: if isParent()
        && request.auth.uid == request.resource.data.parentId
        && request.resource.data.familyId == getUserFamily(request.auth.uid)
        && request.resource.data.keys().hasAll(['parentId', 'familyId', 'createdAt', 'expiresAt']);

      // Parent may delete their own code
      allow delete: if isSignedIn() && request.auth.uid == resource.data.parentId;

      // Kids and other clients should use a secure Cloud Function to verify codes.
    }

    // ── Rewards Collection ────────────────────────────────────────────
    // FIX: Previously ANY signed-in user could read ALL rewards (cross-family leak)
    // Now: Only parent or kids linked to that parent can read
    match /Rewards/{rewardId} {
      // Parent reads rewards in their family
      allow read: if isSignedIn()
        && resource.data.familyId == getUserFamily(request.auth.uid)
        && resource.data.parentId == request.auth.uid;

      // Kid reads rewards belonging to the same family
      allow read: if isSignedIn()
        && isKid()
        && getUserFamily(request.auth.uid) == resource.data.familyId;

      // Only parent may create rewards for their family
      allow create: if isParent()
        && request.auth.uid == request.resource.data.parentId
        && request.resource.data.familyId == getUserFamily(request.auth.uid)
        && request.resource.data.xpCost is int
        && request.resource.data.xpCost >= 1
        && request.resource.data.keys().hasAll(['title', 'xpCost', 'parentId', 'familyId', 'createdAt']);

      // parentId & familyId must be immutable on update
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.parentId
        && request.resource.data.parentId == resource.data.parentId
        && request.resource.data.familyId == resource.data.familyId;

      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.parentId;
    }

    // ── RewardClaims Collection ───────────────────────────────────────
    // Only Cloud Functions create claims; parent/kid can read their own
    match /RewardClaims/{claimId} {
      allow read: if isSignedIn()
        && (resource.data.kidId == request.auth.uid
            || resource.data.parentId == request.auth.uid);

      // Parent marks claim as delivered
      allow update: if isSignedIn()
        && resource.data.parentId == request.auth.uid
        && request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['status']);

      allow create: if false; // Only Cloud Functions
      allow delete: if false;
    }

    // ── Notifications Collection ──────────────────────────────────────
    match /Notifications/{notifId} {
      allow read: if isSignedIn()
        && resource.data.recipientId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['isRead']);

      // Only Cloud Functions create notifications
      allow create: if false;
      allow delete: if isSignedIn()
        && resource.data.recipientId == request.auth.uid;
    }

    // ── Default: Deny everything else ─────────────────────────────────
    // Catch-all: If a document contains `familyId`, require the caller
    // belongs to the same family. Do NOT allow arbitrary client-side creates
    // via this catch-all; only allow reads/updates/deletes within family.
    match /{document=**} {
      // Reads: if resource has familyId, require same family
      allow get, list: if (
        (resource.data.familyId != null && sameFamily(resource.data.familyId))
        ||
        (request.resource != null && request.resource.data.familyId != null && sameFamily(request.resource.data.familyId))
      );

      // Disallow client-side creates in arbitrary collections via catch-all.
      allow create: if false;

      // Updates: ensure familyId is immutable and caller is in same family
      allow update: if resource.data.familyId != null
        && sameFamily(resource.data.familyId)
        && request.resource.data.familyId == resource.data.familyId;

      // Deletes: only allowed for same-family parents
      allow delete: if resource.data.familyId != null && isParent() && sameFamily(resource.data.familyId);
    }
  }
}
