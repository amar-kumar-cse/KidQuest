rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/Users/$(uid)).data;
    }

    function isParentOf(taskData) {
      return isSignedIn() && request.auth.uid == taskData.parentId;
    }

    function isAssignedKid(taskData) {
      return isSignedIn() && request.auth.uid == taskData.assignedToUid;
    }

    function userRole() {
      return getUserData(request.auth.uid).role;
    }

    function isParent() {
      return isSignedIn() && userRole() == 'parent';
    }

    function isKid() {
      return isSignedIn() && userRole() == 'kid';
    }

    // ── Users Collection ──────────────────────────────────────────────
    match /Users/{userId} {
      // User can read own doc
      allow read: if isUser(userId);

      // Parent can read their linked kids' profiles
      allow read: if isSignedIn()
        && isParent()
        && getUserData(request.auth.uid).linkedKids.hasAny([userId]);

      // Kid can read their parent's profile (to see name/avatar)
      allow read: if isSignedIn()
        && isKid()
        && getUserData(request.auth.uid).linkedParentId == userId;

      allow create: if isUser(userId)
        && request.resource.data.keys().hasAll(['uid', 'email', 'name', 'role', 'createdAt'])
        && (request.resource.data.role == 'parent' || request.resource.data.role == 'kid');

      // Self-update: block all sensitive XP/game fields from client writes.
      // These are ONLY updated by Cloud Functions (approveTask, claimReward).
      allow update: if isUser(userId)
        && !request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasAny([
            'totalXp',
            'tasksCompleted',
            'rewardsClaimed',
            'currentStreak',
            'bestStreak',
            'role',
            'linkedKids',
            'linkedParentId'
          ]);

      allow delete: if false; // Never delete user documents from client
    }

    // ── Tasks Collection ─────────────────────────────────────────────
    match /Tasks/{taskId} {
      // Read: Parent (their tasks) or assigned Kid
      allow read: if isParentOf(resource.data) || isAssignedKid(resource.data);

      // Create: Only parents, parentId must match UID
      allow create: if isParent()
        && request.auth.uid == request.resource.data.parentId
        && request.resource.data.xp is int
        && request.resource.data.xp >= 1
        && request.resource.data.xp <= 9999
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll([
             'title', 'description', 'xp', 'status',
             'parentId', 'assignedToUid', 'createdAt', 'dueDate'
           ]);

      // Update:
      // Parent: full rights (approve, reject, edit) — but parentId is immutable
      // Kid: STRICTLY limited — only submit proof
      allow update: if (
        isParentOf(resource.data)
        && request.resource.data.parentId == resource.data.parentId
      ) || (
        isAssignedKid(resource.data)
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['status', 'proofUrl', 'completedAt', 'proofNote'])
        && request.resource.data.status == 'pending_approval'
        && request.resource.data.parentId == resource.data.parentId
        && request.resource.data.assignedToUid == resource.data.assignedToUid
        && request.resource.data.xp == resource.data.xp
      );

      // Delete: Only the parent who owns the task, only if not yet approved
      allow delete: if isParentOf(resource.data)
        && resource.data.status != 'completed';
    }

    // ── FamilyCodes Collection ────────────────────────────────────────
    // FIX: Previously ANY signed-in user could read ALL codes (enumeration risk)
    // Now: Parent can read their OWN code; kid verifies via Cloud Function only
    match /FamilyCodes/{code} {
      // Parent reads their own code (to display it in settings)
      allow read: if isSignedIn()
        && resource.data.parentId == request.auth.uid;

      // Parent creates their family code
      allow create: if isParent()
        && request.auth.uid == request.resource.data.parentId
        && request.resource.data.keys().hasAll(['parentId', 'createdAt', 'expiresAt']);

      // Parent can delete their own code
      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.parentId;

      // NOTE: Kids verify family codes via Cloud Function (verifyFamilyCode),
      // NOT by reading this collection directly. This prevents enumeration attacks.
    }

    // ── Rewards Collection ────────────────────────────────────────────
    // FIX: Previously ANY signed-in user could read ALL rewards (cross-family leak)
    // Now: Only parent or kids linked to that parent can read
    match /Rewards/{rewardId} {
      // Parent reads their own rewards
      allow read: if isSignedIn()
        && resource.data.parentId == request.auth.uid;

      // Kid reads rewards from their linked parent only
      allow read: if isSignedIn()
        && isKid()
        && getUserData(request.auth.uid).linkedParentId == resource.data.parentId;

      // Only parent can create/update/delete rewards
      allow create: if isParent()
        && request.auth.uid == request.resource.data.parentId
        && request.resource.data.xpCost is int
        && request.resource.data.xpCost >= 1
        && request.resource.data.keys().hasAll(['title', 'xpCost', 'parentId', 'createdAt']);

      // FIX: parentId must remain immutable on update
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.parentId
        && request.resource.data.parentId == resource.data.parentId;

      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.parentId;
    }

    // ── RewardClaims Collection ───────────────────────────────────────
    // Only Cloud Functions create claims; parent/kid can read their own
    match /RewardClaims/{claimId} {
      allow read: if isSignedIn()
        && (resource.data.kidId == request.auth.uid
            || resource.data.parentId == request.auth.uid);

      // Parent marks claim as delivered
      allow update: if isSignedIn()
        && resource.data.parentId == request.auth.uid
        && request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['status']);

      allow create: if false; // Only Cloud Functions
      allow delete: if false;
    }

    // ── Notifications Collection ──────────────────────────────────────
    match /Notifications/{notifId} {
      allow read: if isSignedIn()
        && resource.data.recipientId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['isRead']);

      // Only Cloud Functions create notifications
      allow create: if false;
      allow delete: if isSignedIn()
        && resource.data.recipientId == request.auth.uid;
    }

    // ── Default: Deny everything else ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
